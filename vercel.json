{
  "version": 2,
  "public": true,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/home",
      "destination": "/index.html"
    },
    {
      "source": "/select",
      "destination": "/game-select.html"
    },
    {
      "source": "/play",
      "destination": "/game-play.html"
    },
    {
      "source": "/result",
      "destination": "/game-result.html"
    },
    {
      "source": "/admin",
      "destination": "/compare-images.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/**",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000"
        }
      ]
    }
  ]
} 